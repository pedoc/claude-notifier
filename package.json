{
  "name": "claude-notifier",
  "displayName": "Claude Notifier",
  "description": "Plays distinct sounds when Claude Code finishes a task or needs your input",
  "version": "3.1.0",
  "icon": "media/icon.png",
  "publisher": "SingularityInc",
  "repository": {
    "type": "git",
    "url": "https://github.com/ashmitb95/claude-notifier"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claudeNotifier.toggleSound",
        "title": "Claude Notifier: Toggle Sound"
      },
      {
        "command": "claudeNotifier.installTerminalNotifier",
        "title": "Claude Notifier: Install terminal-notifier (clickable macOS notifications)"
      }
    ],
    "configuration": {
      "title": "Claude Notifier",
      "properties": {
        "claudeNotifier.taskCompleted.level": {
          "type": "string",
          "enum": [
            "sound+popup",
            "sound",
            "popup",
            "off"
          ],
          "enumDescriptions": [
            "Play sound and show notification",
            "Play sound only",
            "Show notification only",
            "Disabled"
          ],
          "default": "sound+popup",
          "description": "Notification level when Claude finishes a task."
        },
        "claudeNotifier.taskCompleted.sound": {
          "type": "string",
          "enum": [
            "Basso",
            "Blow",
            "Bottle",
            "Frog",
            "Funk",
            "Glass",
            "Hero",
            "Morse",
            "Ping",
            "Pop",
            "Purr",
            "Sosumi",
            "Submarine",
            "Tink",
            "Windows Notify",
            "tada",
            "chimes",
            "chord",
            "ding",
            "notify",
            "ringin",
            "Windows Background"
          ],
          "default": "Hero",
          "description": "Sound preset when Claude finishes a task. macOS: Basso–Tink. Windows: Windows Notify–Windows Background."
        },
        "claudeNotifier.needsPermission.level": {
          "type": "string",
          "enum": [
            "sound+popup",
            "sound",
            "popup",
            "off"
          ],
          "enumDescriptions": [
            "Play sound and show notification",
            "Play sound only",
            "Show notification only",
            "Disabled"
          ],
          "default": "sound+popup",
          "description": "Notification level when Claude needs permission to use a tool."
        },
        "claudeNotifier.needsPermission.sound": {
          "type": "string",
          "enum": [
            "Basso",
            "Blow",
            "Bottle",
            "Frog",
            "Funk",
            "Glass",
            "Hero",
            "Morse",
            "Ping",
            "Pop",
            "Purr",
            "Sosumi",
            "Submarine",
            "Tink",
            "Windows Notify",
            "tada",
            "chimes",
            "chord",
            "ding",
            "notify",
            "ringin",
            "Windows Background"
          ],
          "default": "Glass",
          "description": "Sound preset when Claude needs permission. macOS: Basso–Tink. Windows: Windows Notify–Windows Background."
        },
        "claudeNotifier.asksQuestion.level": {
          "type": "string",
          "enum": [
            "sound+popup",
            "sound",
            "popup",
            "off"
          ],
          "enumDescriptions": [
            "Play sound and show notification",
            "Play sound only",
            "Show notification only",
            "Disabled"
          ],
          "default": "sound+popup",
          "description": "Notification level when Claude asks you a question."
        },
        "claudeNotifier.asksQuestion.sound": {
          "type": "string",
          "enum": [
            "Basso",
            "Blow",
            "Bottle",
            "Frog",
            "Funk",
            "Glass",
            "Hero",
            "Morse",
            "Ping",
            "Pop",
            "Purr",
            "Sosumi",
            "Submarine",
            "Tink",
            "Windows Notify",
            "tada",
            "chimes",
            "chord",
            "ding",
            "notify",
            "ringin",
            "Windows Background"
          ],
          "default": "Funk",
          "description": "Sound preset when Claude asks a question. macOS: Basso–Tink. Windows: Windows Notify–Windows Background."
        },
        "claudeNotifier.doneDebounceMs": {
          "type": "number",
          "default": 2000,
          "minimum": 0,
          "maximum": 10000,
          "deprecationMessage": "Deprecated and ignored. Per-session stage dedup replaces it. Safe to delete from your settings.",
          "description": "Deprecated and ignored. Per-session stage dedup handles rapid 'done' signal coalescing."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "npx @vscode/vsce package",
    "vscode:uninstall": "node ./out/uninstall.js",
    "test": "npm run test:unit && npm run test:hook",
    "test:unit": "vitest run test/unit",
    "test:hook": "vitest run test/hook",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc -p ./ --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "smoke": "bash scripts/smoke.sh"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6"
  }
}
